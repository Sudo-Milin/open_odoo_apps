<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_preview_wizard_form" model="ir.ui.view">
        <field name="name">import.preview.wizard.form</field>
        <field name="model">import.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Preview">
                <sheet>
                    <div class="oe_title">
                        <h1>Import Preview</h1>
                        <h2>Model: <field name="res_model" readonly="1" class="oe_inline"/></h2>
                    </div>
                    
                    <field name="fallback_values_json" invisible="1"/>

                    <group>
                        <group string="Statistics">
                            <field name="creates_count"/>
                            <field name="updates_count"/>
                            <field name="duplicates_count"/>
                            <field name="no_change_count"/>
                            <field name="warnings_count" invisible="warnings_count == 0"/>
                            <field name="errors_count" invisible="errors_count == 0"/>
                        </group>
                    </group>
                    
                    <group string="Duplicate Detection">
                        <label for="duplicate_match_field_ids" string="Check Duplicates On"/>
                        <div class="o_row">
                            <field name="duplicate_match_field_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <button name="action_recalculate_duplicates" string="Recalculate" type="object" class="btn-secondary ml-2"/>
                        </div>
                    </group>

                    <notebook>
                        <page string="Preview Rows">
                            <!-- Custom widget to render the OWL table -->
                            <field name="preview_data" widget="import_preview_table"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_confirm_import" string="Close &amp; Proceed to Import" type="object" class="btn-primary" data-hotkey="q"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
